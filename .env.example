# Copy this file to .env (Next.js: .env.local) and fill in real values.
# .env and .env.* are gitignored; .env.example is the ONLY .env* file in the repo.
# NEVER put a real key in this file.

# Required for Claude-powered analysis. Without this the server uses the local heuristic engine.
ANTHROPIC_API_KEY=

# Optional: enables Gemini AI evaluation of the recommendation + next steps.
# Without this, the Confidence Score panel is hidden.
GEMINI_API_KEY=

# Optional: override the Anthropic model. Defaults to claude-sonnet-4-6.
# Note: claude-sonnet-4-6 accepts temperature; the analyze/extract calls pin
# temperature:0 for determinism. Newer models (claude-sonnet-5, claude-opus-4-8,
# claude-fable-5) REJECT temperature with a 400 — switching to one requires
# dropping temperature:0 from lib/analyze-claude.js, lib/extract.js, and server.ps1.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: override the Gemini model. Defaults to gemini-2.5-flash-lite.
# (gemini-2.0-flash has a free-tier limit of 0 on some accounts — avoid it.)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: HTTP port (PowerShell backend). Defaults to 4321.
# PORT=4321
